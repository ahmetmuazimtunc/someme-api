# Application
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001

# Database (PostgreSQL)
DATABASE_URL=postgresql://someme_user:YOUR_DB_PASSWORD@localhost:5432/someme_db

# Redis
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@127.0.0.1:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRES_IN=30d

# DigitalOcean Spaces (S3-compatible)
DO_SPACES_KEY=your_spaces_access_key
DO_SPACES_SECRET=your_spaces_secret_key
DO_SPACES_ENDPOINT=https://lon1.digitaloceanspaces.com
DO_SPACES_BUCKET=someme1
DO_SPACES_REGION=lon1
DO_SPACES_CDN_ENDPOINT=https://someme1.lon1.digitaloceanspaces.com

# Email (SMTP) — use Gmail App Password, Mailgun, or SendGrid
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@someme.app

# Social Auth
GOOGLE_CLIENT_ID=your-google-oauth-client-id
