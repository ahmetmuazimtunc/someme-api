# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# Production frontend / mobile app origin (comma-separated if multiple)
FRONTEND_URL=https://someme.app

# ─── Database (local PostgreSQL on the droplet) ────────────────────────────────
DATABASE_URL=postgresql://someme_user:STRONG_DB_PASSWORD@127.0.0.1:5432/someme_db

# OR — DigitalOcean Managed Database (sslmode required)
# DATABASE_URL=postgresql://doadmin:PASSWORD@db-host.k.db.ondigitalocean.com:25060/defaultdb?sslmode=require

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:STRONG_REDIS_PASSWORD@127.0.0.1:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_64_BYTE_BASE64_SECRET
JWT_EXPIRES_IN=7d

# Generate with: openssl rand -base64 64
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_64_BYTE_BASE64_SECRET
JWT_REFRESH_EXPIRES_IN=30d

# ─── DigitalOcean Spaces ──────────────────────────────────────────────────────
DO_SPACES_KEY=your_spaces_access_key
DO_SPACES_SECRET=your_spaces_secret_key
DO_SPACES_ENDPOINT=https://lon1.digitaloceanspaces.com
DO_SPACES_BUCKET=someme1
DO_SPACES_REGION=lon1
DO_SPACES_CDN_ENDPOINT=https://someme1.lon1.digitaloceanspaces.com

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@someme.app
SMTP_PASS=your_google_app_password
SMTP_FROM=info@someme.app
SMTP_SENDER_NAME=SoMeme Team

# ─── Social Auth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_oauth_client_id
